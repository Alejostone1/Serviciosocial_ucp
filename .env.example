# ============================================================
# VARIABLES DE ENTORNO - SISTEMA SERVICIO SOCIAL UCP
# Copiar este archivo como .env.local y completar los valores
# NUNCA subir .env.local al repositorio de git
# ============================================================

# ── BASE DE DATOS ──────────────────────────────────────────
DATABASE_URL="postgresql://bdservicioucp:Android.13@localhost:5432/bdserviciosocialucp?schema=public"

# ── NEXTAUTH ────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera_un_secreto_seguro_con_openssl_rand_base64_32"

# ── CORREO (para recuperación de contraseña) ───────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="notificaciones@ucp.edu.co"
SMTP_PASS="tu_app_password_aqui"
SMTP_FROM="Sistema Servicio Social UCP <notificaciones@ucp.edu.co>"

# ── ALMACENAMIENTO DE ARCHIVOS ──────────────────────────────
# Opción A: Local (desarrollo)
UPLOAD_DIR="./public/uploads"
UPLOAD_BASE_URL="http://localhost:3000/uploads"
# Opción B: S3/Cloudflare R2 (producción)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""

# ── GENERACIÓN DE PDF ──────────────────────────────────────
# URL base para los certificados generados
CERT_BASE_URL="http://localhost:3000"

# ── CONFIGURACIÓN APP ──────────────────────────────────────
APP_NAME="Sistema de Servicio Social UCP"
APP_URL="http://localhost:3000"
NODE_ENV="development"
