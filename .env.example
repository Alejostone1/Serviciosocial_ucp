# ============================================================
# VARIABLES DE ENTORNO - SISTEMA SERVICIO SOCIAL UCP
# ============================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.local
# 2. Completar los valores según tu configuración
# 3. NUNCA subir .env.local al repositorio de git
# 4. Reiniciar el servidor después de cambiar variables
# ============================================================

# ── BASE DE DATOS (OBLIGATORIO) ──────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/base_datos?schema=public
DATABASE_URL="postgresql://postgres:Android.13@localhost:5432/bdservicioucp?schema=public"

# ── NEXTAUTH (OBLIGATORIO) ────────────────────────────────────────
# URL donde corre la aplicación (desarrollo/producción)
NEXTAUTH_URL="http://localhost:3000"

# Secreto para firmar tokens JWT (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET="cambia_esto_por_un_secreto_seguro_de_32_caracteres"

# ── LOGOS UCP (OPCIONAL) ───────────────────────────────────────────
# Si se definen, se usan las URLs de Cloudinary (o cualquier CDN)
# Si NO se definen, se sirven los archivos locales de /public/uploads
#
# Uso en Cloudinary:
#   1. Sube logo_ucp_redondo.png y logo-ucp.png al Media Library de tu cuenta
#   2. Copia la URL "Delivery URL" de cada archivo
#   3. Pégala abajo y reinicia el servidor
#
# Opción A: Local (desarrollo) - archivos en /public/uploads/
# NEXT_PUBLIC_LOGO_ROUND=""
# NEXT_PUBLIC_LOGO_WIDE=""
#
# Opción B: Cloudinary/CDN (producción)
# NEXT_PUBLIC_LOGO_ROUND=https://res.cloudinary.com/<tu-cloud>/image/upload/logo_ucp_redondo.png
# NEXT_PUBLIC_LOGO_WIDE=https://res.cloudinary.com/<tu-cloud>/image/upload/logo-ucp.png

# ── CORREO ELECTRÓNICO (OPCIONAL - Recuperación de contraseña) ──
# Configuración SMTP para envío de correos
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="notificaciones@ucp.edu.co"
SMTP_PASS="tu_app_password_de_gmail_aqui"
SMTP_FROM="Sistema Servicio Social UCP <notificaciones@ucp.edu.co>"

# ── WHATSAPI (OPCIONAL - Notificaciones WhatsApp) ───────────────────
# API Key para WhatsApp Business API (opcional, usa simulación si no se configura)
WHATSAPP_API_KEY=""
WHATSAPP_API_URL="https://api.whatsapp.com"

# ── ALMACENAMIENTO DE ARCHIVOS ────────────────────────────────────
# Configuración para subida de archivos (certificados, evidencias, etc.)

# Opción A: Local (desarrollo)
UPLOAD_DIR="./public/uploads"
UPLOAD_BASE_URL="http://localhost:3000/uploads"

# Opción B: S3/Cloudflare R2 (producción) - Descomentar y configurar
# S3_BUCKET="nombre-del-bucket"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="tu_access_key"
# S3_SECRET_KEY="tu_secret_key"
# S3_ENDPOINT="https://tu-endpoint.r2.cloudflarestorage.com"

# ── GENERACIÓN DE PDF Y CERTIFICADOS ───────────────────────────────
# URL base para los certificados generados (debe coincidir con APP_URL)
CERT_BASE_URL="http://localhost:3000"

# ── CONFIGURACIÓN DE LA APLICACIÓN ─────────────────────────────────
APP_NAME="Sistema de Servicio Social UCP"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── CONFIGURACIÓN ADICIONAL (OPCIONAL) ───────────────────────────────
# Timezone para fechas (formato: America/Bogota)
TZ="America/Bogota"

# Puerto para el servidor de desarrollo (opcional, Next.js usa 3000 por defecto)
PORT=3000

# ============================================================
# VALIDACIÓN DE VARIABLES
# ============================================================
#
# Variables OBLIGATORIAS (el sistema no iniciará sin ellas):
# • DATABASE_URL - Conexión a PostgreSQL
# • NEXTAUTH_URL - URL de la aplicación
# • NEXTAUTH_SECRET - Secreto JWT (mínimo 10 caracteres)
#
# Variables OPCIONALES (el sistema funcionará sin ellas):
# • NEXT_PUBLIC_LOGO_* - Logos UCP (usa locales si no se definen)
# • SMTP_* - Correo para recuperación de contraseña
# • WHATSAPP_* - Notificaciones WhatsApp
# • UPLOAD_* - Almacenamiento de archivos
# • S3_* - Almacenamiento en la nube
# • CERT_BASE_URL - URL base para certificados
# • APP_NAME, APP_URL - Configuración general
# • NODE_ENV - Entorno (development/production)
# • TZ, PORT - Configuración adicional
#
# ============================================================
# EJEMPLOS DE CONFIGURACIÓN
# ============================================================
#
# Base de datos local:
# DATABASE_URL="postgresql://postgres:mipassword@localhost:5432/mi_db?schema=public"
#
# Base de datos en la nube:
# DATABASE_URL="postgresql://usuario:password@host.rds.amazonaws.com:5432/mi_db?schema=public"
#
# NextAuth en producción:
# NEXTAUTH_URL="https://miservicio.ucp.edu.co"
# NEXTAUTH_SECRET="abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234"
#
# Logos en Cloudinary:
# NEXT_PUBLIC_LOGO_ROUND=https://res.cloudinary.com/mi-cloud/image/upload/logo_ucp_redondo.png
# NEXT_PUBLIC_LOGO_WIDE=https://res.cloudinary.com/mi-cloud/image/upload/logo-ucp.png
#
# Correo Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="miucp@gmail.com"
# SMTP_PASS="abcd 1234 efgh 5678"  # App password de Google
#
# Correo Outlook/Hotmail:
# SMTP_HOST="smtp-mail.outlook.com"
# SMTP_PORT=587
# SMTP_USER="miucp@outlook.com"
# SMTP_PASS="mi_password"
#
# Almacenamiento S3:
# S3_BUCKET="mi-bucket-ucp"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="AKIAIOSFODNN7EXAMPLE"
# S3_SECRET_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# S3_ENDPOINT="https://s3.amazonaws.com"
#
# ============================================================
