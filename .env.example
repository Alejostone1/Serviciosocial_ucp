# ============================================================
# VARIABLES DE ENTORNO - SISTEMA SERVICIO SOCIAL UCP
# ============================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.local (para desarrollo local)
# 2. Completar los valores según tu configuración
# 3. NUNCA subir .env.local al repositorio de git
# 4. Reiniciar el servidor después de cambiar variables
# ============================================================

# -- BASE DE DATOS (OBLIGATORIO) ----------------------------------
DATABASE_URL="postgresql://postgres:Android.13@localhost:5432/bdservicioucp?schema=public"

# -- NEXTAUTH (OBLIGATORIO) ----------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia_esto_por_un_secreto_seguro_de_32_caracteres"

# -- CORREO ELECTRÓNICO (OPCIONAL - Recuperación de contraseńa) --
# Configuración SMTP para envío de correos
# Para Gmail: https://support.google.com/accounts/answer/185833

# Opción 1: Gmail (recomendado para desarrollo)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="ucpserviciosocial@gmail.com"
SMTP_PASS="tu_app_password_de_16_caracteres"
SMTP_FROM="Sistema Servicio Social UCP <ucpserviciosocial@gmail.com>"

# -- ALMACENAMIENTO DE ARCHIVOS ------------------------------------
UPLOAD_DIR="./public/uploads"
UPLOAD_BASE_URL="http://localhost:3000/uploads"

# -- GENERACIÓN DE PDF Y CERTIFICADOS -------------------------------
CERT_BASE_URL="http://localhost:3000"

# -- CONFIGURACIÓN DE LA APLICACIÓN ---------------------------------
APP_NAME="Sistema de Servicio Social UCP"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
TZ="America/Bogota"

# ============================================================
# NOTAS PARA RECUPERACIÓN DE CONTRASEŃA:
# ============================================================
# 1. Configurar las variables SMTP_* arriba
# 2. Para Gmail: generar App Password en https://myaccount.google.com/apppasswords
# 3. El sistema usará SMTP_FROM como remitente de los correos
# 4. NEXT_PUBLIC_APP_URL se usa para generar los links de recuperación
# ============================================================
